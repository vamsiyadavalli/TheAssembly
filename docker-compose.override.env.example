# Copy this file to docker-compose.override.env and fill in your values.
# This file is intentionally NOT committed — it holds your secrets locally.
#
# Tip: Use split tokens for tighter security.
#   GITHUB_READ_TOKEN  — Contents: Read-only  (athlete app)
#   GITHUB_WRITE_TOKEN — Contents: Read+Write (admin app)
# Or use a single GITHUB_TOKEN as fallback for both.

GITHUB_READ_TOKEN=ghp_your_read_only_token_here
GITHUB_WRITE_TOKEN=ghp_your_read_write_token_here

WORKOUTS_REPO_OWNER=your_github_owner
WORKOUTS_REPO_NAME=YourGymName-data
WORKOUTS_REPO_BRANCH=main
WORKOUTS_FILE_PATH=workouts.json
CURRENT_STATE_FILE_PATH=current_state.json

APP_TIMEZONE=America/New_York
ADMIN_PASSWORD=change_me_before_use
