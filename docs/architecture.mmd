%% High-Level Overview — see architecture-app.mmd for app internals, architecture-infra.mmd for deployment details
graph TD
    subgraph GymOwnerSetup["🏋️ Gym Owner Setup"]
        Template["TheAssembly\n(public template repo)"]
        DataTemplate["TheAssemblyData-template\n(public starter repo)"]
        GymRepo["YourGymName app repo\n(forked from template)"]
        GymData["YourGymName-data\n(private — YOUR IP)"]
        PAT["GitHub PAT\nRead-only → athlete app\nRead+Write → admin app"]
        StreamlitSecrets["Streamlit Cloud Secrets\nGITHUB_READ_TOKEN → athlete\nGITHUB_WRITE_TOKEN → admin\n(both map to GITHUB_TOKEN in-app)\nWORKOUTS_REPO_OWNER etc."]
        Template --> GymRepo
        DataTemplate --> GymData
        PAT --> StreamlitSecrets
        GymData -.->|"stays private forever"| GymData
    end

    subgraph DeploymentPaths["🚀 Deployment — see architecture-infra.mmd"]
        StreamlitCloud["☁️ Streamlit Community Cloud\nasm-athlete.streamlit.app\nasm-control.streamlit.app"]
        SelfHosted["🐳 Self-Hosted\nDocker · Kubernetes · Traefik\nasm-athlete.theassembly.app\nasm-control.theassembly.app"]
    end

    subgraph AppCode["📦 Application Code — see architecture-app.mmd"]
        AppNode["streamlit_app.py + theassembly/\nconfig · models · github_repo · schedule\nanalytics · weather · jokes · hn_topics\nworkout_formatting · workout_poster"]
    end

    subgraph PrivateDataRepo["🔒 YourGymName-data (Private GitHub Repo)"]
        WorkoutsJSON["workouts.json\narray of WorkoutRecord objects"]
        StateJSON["current_state.json\n{ status: open | closed }"]
    end

    subgraph GitHubAPI["🐙 GitHub REST API (Contents API)"]
        ContentsAPI["GET /repos/:owner/:repo/contents/:path\nPUT /repos/:owner/:repo/contents/:path"]
    end

    subgraph TimeLogic["⏰ Time-Based Logic Windows (America/New_York)"]
        Overnight["Overnight\n12:00 AM – 10:59 AM\n→ Show today's workout"]
        Closed["Daytime Closed\n11:00 AM – 3:59 PM\n→ Garage Closed"]
        Preview["Preview\n4:00 PM – 11:59 PM\n→ Show tomorrow's workout"]
    end

    subgraph CI["🔄 GitHub Actions"]
        TestsWF[".github/workflows/tests.yml\nunit tests + ruff lint\npush/PR to dev + master"]
        MonitorWF[".github/workflows/workout-monitoring.yml\nvalidates data repo\ncron: 12:05 PM + 9:05 PM ET · manual dispatch"]
    end

    GymRepo --> DeploymentPaths
    StreamlitSecrets --> AppCode
    DeploymentPaths --> AppCode
    AppCode -->|"HTTP GET/PUT + Bearer token"| ContentsAPI
    ContentsAPI --> WorkoutsJSON
    ContentsAPI --> StateJSON
    AppCode --> TimeLogic
    CI -->|"reads + validates"| PrivateDataRepo

