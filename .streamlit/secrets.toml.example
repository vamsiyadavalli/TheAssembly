# Read-only token for athlete app deployment
GITHUB_READ_TOKEN = "ghp_read_only_token"

# Read-write token for admin app deployment
GITHUB_WRITE_TOKEN = "ghp_read_write_token"

WORKOUTS_REPO_OWNER = "your_github_owner"
WORKOUTS_REPO_NAME = "TheAssemblyData"
WORKOUTS_REPO_BRANCH = "master"
WORKOUTS_FILE_PATH = "workouts.json"
CURRENT_STATE_FILE_PATH = "current_state.json"
APP_TIMEZONE = "America/New_York"
ADMIN_PASSWORD = "change_me"

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Set ANALYTICS_ENABLED = true to activate GA4 + Microsoft Clarity tracking.
# Leave unset or false to run fully analytics-free.
ANALYTICS_ENABLED = false
GA4_MEASUREMENT_ID = "G-XXXXXXXXXX"
GA4_MP_API_SECRET  = "your_mp_api_secret"
CLARITY_PROJECT_ID = "your_clarity_project_id"
